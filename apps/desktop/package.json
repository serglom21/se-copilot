{
  "name": "@se-copilot/desktop",
  "version": "0.1.0",
  "main": "dist-electron/main.js",
  "description": "Pawprint — Leave a trace everywhere",
  "author": "Sentry",
  "private": true,
  "scripts": {
    "dev": "vite",
    "build": "vite build && electron-builder",
    "typecheck": "tsc --noEmit",
    "preview": "vite preview",
    "test": "vitest run tests/unit",
    "test:unit": "vitest run tests/unit",
    "test:e2e": "npx tsx tests/e2e/runner.ts && npx vitest run tests/e2e/phases",
    "test:e2e:assert": "npx vitest run tests/e2e/phases"
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1.0.5",
    "@radix-ui/react-dropdown-menu": "^2.0.6",
    "@radix-ui/react-select": "^2.0.0",
    "@radix-ui/react-tabs": "^1.0.4",
    "@sentry/electron": "^7.7.1",
    "@sentry/node": "^10.38.0",
    "@sentry/react": "^10.38.0",
    "@types/diff": "^8.0.0",
    "better-sqlite3": "^9.2.2",
    "bufferutil": "^4.1.0",
    "chance": "^1.1.13",
    "clsx": "^2.1.0",
    "diff": "^8.0.4",
    "dotenv": "^17.3.1",
    "lucide-react": "^0.577.0",
    "puppeteer": "^24.36.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.21.1",
    "recharts": "^2.15.4",
    "simple-git": "^3.22.0",
    "ts-morph": "^27.0.2",
    "utf-8-validate": "^6.0.6",
    "zod": "^3.22.4",
    "zustand": "^4.4.7"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.9",
    "@types/node": "^20.10.6",
    "@types/react": "^18.2.46",
    "@types/react-dom": "^18.2.18",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.16",
    "electron": "28.3.3",
    "electron-builder": "^24.9.1",
    "postcss": "^8.4.33",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.3.3",
    "vite": "^5.0.10",
    "vite-plugin-electron": "^0.28.1",
    "vite-plugin-electron-renderer": "^0.14.5",
    "vitest": "^1.1.1"
  },
  "build": {
    "appId": "io.sentry.pawprint",
    "productName": "Pawprint",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*"
    ],
    "mac": {
      "category": "public.app-category.developer-tools",
      "target": [
        "dmg",
        "zip"
      ]
    },
    "win": {
      "target": [
        "nsis",
        "zip"
      ]
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ]
    }
  }
}
